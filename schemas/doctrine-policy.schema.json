{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://electri-city-ops.local/schemas/doctrine-policy.schema.json",
  "title": "Doctrine Policy",
  "type": "object",
  "required": [
    "policy_version",
    "canonical_docs",
    "defaults",
    "workspace",
    "external_effects",
    "gates",
    "ai_management",
    "lifecycle",
    "scopes",
    "blast_radius",
    "simulation"
  ],
  "properties": {
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "canonical_docs": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "defaults": {
      "type": "object",
      "required": [
        "fallback_gate",
        "approval_gate"
      ],
      "properties": {
        "fallback_gate": {
          "type": "string"
        },
        "approval_gate": {
          "type": "string"
        }
      }
    },
    "workspace": {
      "type": "object",
      "required": [
        "root_only",
        "forbid_outside_workspace",
        "forbid_rocket_cloud_changes"
      ],
      "properties": {
        "root_only": {
          "type": "boolean"
        },
        "forbid_outside_workspace": {
          "type": "boolean"
        },
        "forbid_rocket_cloud_changes": {
          "type": "boolean"
        }
      }
    },
    "external_effects": {
      "type": "object",
      "required": [
        "runtime_connector_activation",
        "require_approval",
        "blocked_targets"
      ],
      "properties": {
        "runtime_connector_activation": {
          "type": "boolean"
        },
        "require_approval": {
          "type": "boolean"
        },
        "blocked_targets": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "gates": {
      "type": "object",
      "required": [
        "allowed_states"
      ],
      "properties": {
        "allowed_states": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "ai_management": {
      "type": "object",
      "required": [
        "system_register_required",
        "impact_assessment_required",
        "provenance_required",
        "supply_chain_verification_required",
        "human_oversight_required_for_external_effects",
        "risk_classes"
      ],
      "properties": {
        "system_register_required": {
          "type": "boolean"
        },
        "impact_assessment_required": {
          "type": "boolean"
        },
        "provenance_required": {
          "type": "boolean"
        },
        "supply_chain_verification_required": {
          "type": "boolean"
        },
        "human_oversight_required_for_external_effects": {
          "type": "boolean"
        },
        "risk_classes": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "lifecycle": {
      "type": "object",
      "required": [
        "required_stages"
      ],
      "properties": {
        "required_stages": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    },
    "scopes": {
      "type": "object",
      "required": [
        "forbidden_patterns",
        "require_explicit_external_scope"
      ],
      "properties": {
        "forbidden_patterns": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "require_explicit_external_scope": {
          "type": "boolean"
        }
      }
    },
    "blast_radius": {
      "type": "object",
      "required": [
        "allowed_values",
        "blocked_values"
      ],
      "properties": {
        "allowed_values": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        },
        "blocked_values": {
          "type": "array",
          "items": {
            "type": "string"
          }
        }
      }
    },
    "simulation": {
      "type": "object",
      "required": [
        "required_fields"
      ],
      "properties": {
        "required_fields": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "string"
          }
        }
      }
    }
  }
}
