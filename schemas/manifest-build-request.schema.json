{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://electri-city-ops.local/schemas/manifest-build-request.schema.json",
  "title": "Manifest Build Request",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "license_id",
    "policy_registry_id",
    "rollback_registry_id",
    "requested_channel",
    "plugin_version",
    "package_basename",
    "min_plugin_version",
    "conflict_blocklist_version",
    "issued_at"
  ],
  "properties": {
    "license_id": {
      "type": "string",
      "minLength": 1
    },
    "policy_registry_id": {
      "type": "string",
      "minLength": 1
    },
    "rollback_registry_id": {
      "type": "string",
      "minLength": 1
    },
    "requested_channel": {
      "type": "string",
      "enum": ["stable", "pilot", "rollback"]
    },
    "plugin_version": {
      "type": "string",
      "minLength": 1
    },
    "package_basename": {
      "type": "string",
      "minLength": 1
    },
    "min_plugin_version": {
      "type": "string",
      "minLength": 1
    },
    "conflict_blocklist_version": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
