{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://electri-city-ops.local/schemas/plugin-package-metadata.schema.json",
  "title": "Plugin Package Metadata",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "plugin_slug",
    "plugin_version",
    "release_channel",
    "package_basename",
    "package_filename",
    "package_sha256",
    "file_count",
    "build_mode",
    "built_at"
  ],
  "properties": {
    "plugin_slug": {
      "type": "string",
      "minLength": 1
    },
    "plugin_version": {
      "type": "string",
      "minLength": 1
    },
    "release_channel": {
      "type": "string",
      "enum": ["stable", "pilot", "rollback"]
    },
    "package_basename": {
      "type": "string",
      "minLength": 1
    },
    "package_filename": {
      "type": "string",
      "minLength": 1
    },
    "package_sha256": {
      "type": "string",
      "minLength": 1
    },
    "file_count": {
      "type": "integer",
      "minimum": 1
    },
    "build_mode": {
      "type": "string",
      "enum": ["local_preview_only"]
    },
    "built_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
