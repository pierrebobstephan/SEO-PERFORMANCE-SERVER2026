{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://electri-city-ops.local/schemas/plugin-policy-response.schema.json",
  "title": "Plugin Policy Response",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "license_id",
    "bound_domain",
    "release_channel",
    "policy_version",
    "default_mode",
    "allowed_scopes",
    "module_flags",
    "rollback_profile_id",
    "issued_at"
  ],
  "properties": {
    "license_id": {
      "type": "string",
      "minLength": 1
    },
    "bound_domain": {
      "type": "string",
      "minLength": 1
    },
    "release_channel": {
      "type": "string",
      "enum": ["stable", "pilot", "rollback"]
    },
    "policy_version": {
      "type": "string",
      "minLength": 1
    },
    "default_mode": {
      "type": "string",
      "enum": ["safe_mode", "observe_only", "approval_required", "active_scoped"]
    },
    "allowed_scopes": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "module_flags": {
      "type": "object"
    },
    "rollback_profile_id": {
      "type": "string",
      "minLength": 1
    },
    "issued_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
