{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://electri-city-ops.local/schemas/release-artifact.schema.json",
  "title": "Release Artifact",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "artifact_id",
    "plugin_slug",
    "plugin_version",
    "release_channel",
    "package_metadata",
    "manifest",
    "entitlement",
    "build_mode",
    "built_at"
  ],
  "properties": {
    "artifact_id": {
      "type": "string",
      "minLength": 1
    },
    "plugin_slug": {
      "type": "string",
      "minLength": 1
    },
    "plugin_version": {
      "type": "string",
      "minLength": 1
    },
    "release_channel": {
      "type": "string",
      "enum": ["stable", "pilot", "rollback"]
    },
    "package_metadata": {
      "$ref": "plugin-package-metadata.schema.json"
    },
    "manifest": {
      "$ref": "update-manifest.schema.json"
    },
    "entitlement": {
      "$ref": "domain-entitlement.schema.json"
    },
    "build_mode": {
      "type": "string",
      "enum": ["local_preview_only"]
    },
    "built_at": {
      "type": "string",
      "minLength": 1
    }
  }
}
